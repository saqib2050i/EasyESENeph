# Copy to .env (same folder as docker-compose.unraid.yml) and fill all three.
# Generate a strong password with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(16))"

AUTH_USER=admin
AUTH_PASSWORD=change-me

# Host folder that holds the deck (data.json) + auth secrets. On Unraid use an
# absolute appdata path so it persists independently of where you run compose.
DATA_DIR=/mnt/user/appdata/nephron
